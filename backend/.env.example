# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/xyvora-store?retryWrites=true&w=majority

# Server port
PORT=5000

# Secret used to sign admin JWT tokens — change this to a long random string
JWT_SECRET=change_this_to_a_long_random_secret_string

# Simple admin login (as requested — env based, no DB user table)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password

# WhatsApp business number for orders, with country code, no + or spaces
# Example: 919876543210
WHATSAPP_NUMBER=919999999999

# Cloudinary (for product image uploads) — sign up free at cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Comma separated list of allowed origins for CORS (your deployed frontend URL)
CLIENT_ORIGIN=http://localhost:5173
